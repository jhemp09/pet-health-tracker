# Supabase (from your Supabase project's Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never expose to the client. Used by cron/notification routes.
SUPABASE_SERVICE_ROLE_KEY=

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Shared secret so only Vercel Cron can trigger the notification-sending route
CRON_SECRET=
